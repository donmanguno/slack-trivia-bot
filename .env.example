# Slack Bot Token (xoxb-...)
SLACK_BOT_TOKEN=

# Slack App-Level Token (xapp-...) for Socket Mode
SLACK_APP_TOKEN=

# Set to 1 for verbose debug logging (answer matching, state changes, etc.)
TRIVIA_DEBUG=0

# Comma-separated Slack user IDs allowed to remove channel data from App Home
# e.g. TRIVIA_ADMIN_USERS=U012AB3CD,U098ZY7WX
TRIVIA_ADMIN_USERS=
